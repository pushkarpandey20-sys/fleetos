# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fleetos:fleetos_dev_pass@localhost:5432/fleetos

# ── Kafka ─────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=fleetos_dev_jwt_secret_change_in_production_min_64_chars_long
ENCRYPTION_KEY=fleetos_dev_enc_key_32chars!!!!!

# ── Service Ports ─────────────────────────────────────────────────────
ORDER_SERVICE_PORT=3001
RIDER_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003
BILLING_SERVICE_PORT=3004
WS_PORT=3005

# ── URLs ──────────────────────────────────────────────────────────────
TRACKING_BASE_URL=http://localhost:3000/track
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── OSRM ─────────────────────────────────────────────────────────────
OSRM_URL=http://localhost:5000

# ── Twilio (SMS / WhatsApp) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Firebase (Push Notifications) ────────────────────────────────────
FCM_SERVER_KEY=your_fcm_server_key_here
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Razorpay (Payments) ───────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── AWS S3 (POD Images) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=fleetos-pod-dev
AWS_REGION=ap-south-1

# ── Support ───────────────────────────────────────────────────────────
SUPPORT_PHONE=+911800000000

# ── Environment ───────────────────────────────────────────────────────
NODE_ENV=development
