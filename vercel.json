{
  "version": 2,
  "buildCommand": "cd services/order-service && npm install --ignore-scripts && npm run build",
  "installCommand": "echo skip",
  "outputDirectory": "services/order-service/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}